# FPL account credentials
# Required for authenticated endpoints (e.g. my-team).
# The main player stats scrape uses public endpoints and does not strictly
# require login, but credentials are needed if FPL starts requiring auth.
FPL_LOGIN=your_email@example.com
FPL_PASSWORD=your_password

# Database path (default: data/fpl.db relative to project root)
# DB_PATH=/custom/path/fpl.db

# Rate limiting (seconds between requests)
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=3.0

# Retry settings
BACKOFF_FACTOR=2.0
MAX_RETRIES=5
MAX_BACKOFF=120.0
REQUEST_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
